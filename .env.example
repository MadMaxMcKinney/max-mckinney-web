# Payload CMS environment
# Copy to `.env` and fill in. Do not commit real secrets.

# MongoDB connection string (Vercel Storage / MongoDB Atlas)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/maxmckinney

# Secret used to sign Payload tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Vercel Blob store read/write token
BLOB_READ_WRITE_TOKEN=
